# Cloudflare Pages routing for the House of Mastery tools.
# First Hour lives at first-hour/index.html and is served directly at
# /first-hour/ via directory routing — no rewrite needed.
# KOORA is the homepage; /koora 301-redirects to /.
# Privacy retains a single-file rewrite for now.
# FAQ pages: clean URLs that rewrite to the .html files.
/koora / 301
/koora/ / 301
# First Hour must serve identical HTML with and without the trailing slash.
# Keep both rewrites explicit so Cloudflare Pages does not emit its automatic
# directory 308 before returning the assessment HTML.
/first-hour /first-hour/index.html 200
/first-hour/ /first-hour/index.html 200
# Partner embed route must remain directly fetchable as /embed.html because
# downstream integrations probe that exact filename path.
/embed.html /embed.html 200
# Stub redirect until /mastery-hour page exists - prevents rung-3 404
# bleeds and crawl-budget loss. Point to /about#programmes interim.
/mastery-hour /about#programmes 302
/mastery-hour/ /about#programmes 302
/privacy /privacy.html 200
/privacy/ /privacy.html 200
/about /about.html 200
/about/ /about.html 200
/koora-faq /koora-faq.html 200
/koora-faq/ /koora-faq.html 200
/first-hour-faq /first-hour-faq.html 200
/first-hour-faq/ /first-hour-faq.html 200
